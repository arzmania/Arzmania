# Auto detect text files and normalize line endings to LF
* text=auto

# Fichiers texte
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Fichiers binaires
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp3 binary
*.mp4 binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
